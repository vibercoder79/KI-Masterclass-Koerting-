    {"type":"text","id":"core_list","x":360,"y":170,"width":380,"height":390,"text":"1. Verstehen\n   Use-Cases · Trigger-Phrasen\n\n2. Ressourcen planen\n   Scripts · Refs · Assets\n\n3. INIT\n   init_skill.py\n   → SKILL.md + Struktur\n\n4. Umsetzen\n   Ressourcen zuerst\n   SKILL.md < 300 Zeilen\n   Scripts testen\n\n5. VALIDIEREN & PAKETIEREN\n   package_skill.py\n   → .skill-Datei\n\n6. Iterieren\n   Einsetzen · Lernen\n\nPrinzip:\n · Kuerze\n · Progressive Disclosure\n · Skills fuer KI, nicht Menschen","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1d1d1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"seed":9206,"version":1,"versionNonce":9207,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

